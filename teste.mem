// Programa completo: addi, add, sub, and, or, sw, lw, beq (nao tomado), jump
// Regra: instrução que lê $X deve estar >= 4 posições depois de quem escreve em $X.
// nop = addi $0,$0,0 (escreve em $0, protegido contra writeback)
// Resultado esperado: $1=1 $2=4 $3=14 $4=6 $5=0 $6=14 $7=25  M[0]=14
0100000001001010 // [0]  addi $1,$0,10    -> $1=10
0100000010000100 // [1]  addi $2,$0,4     -> $2=4
0100000000000000 // [2]  nop
0100000000000000 // [3]  nop
0100000000000000 // [4]  nop
0000001010011000 // [5]  add $3,$1,$2     -> $3=14  ($1 ok:5-0=5, $2 ok:5-1=4)
0100000000000000 // [6]  nop
0100000000000000 // [7]  nop
0100000000000000 // [8]  nop
0000001010100010 // [9]  sub $4,$1,$2     -> $4=6   ($1 ok:9-0=9, $2 ok:9-1=8)
0100000000000000 // [10] nop
0100000000000000 // [11] nop
0100000000000000 // [12] nop
0000001010101100 // [13] and $5,$1,$2     -> $5=0   ($1 ok:13-0=13, $2 ok:13-1=12)
0100000000000000 // [14] nop
0100000000000000 // [15] nop
0100000000000000 // [16] nop
0000001010110101 // [17] or  $6,$1,$2     -> $6=14  ($1 ok:17-0=17, $2 ok:17-1=16)
0100000000000000 // [18] nop
0100000000000000 // [19] nop
0100000000000000 // [20] nop
1111000011000000 // [21] sw  $3,0($0)     -> M[0]=14 ($3 ok:21-5=16)
0100000000000000 // [22] nop
0100000000000000 // [23] nop
0100000000000000 // [24] nop
1011000111000000 // [25] lw  $7,0($0)     -> $7=14
0100000000000000 // [26] nop
0100000000000000 // [27] nop
0100000000000000 // [28] nop
1000100010000011 // [29] beq $4,$2,3      -> nao tomado ($4=6 != $2=4) ($4 ok:29-9=20, $2 ok:29-1=28)
0100000001000001 // [30] addi $1,$0,1     -> $1=1   (executa, beq nao tomado)
0100000000000000 // [31] nop
0100000000000000 // [32] nop
0100000000000000 // [33] nop
0100000000000000 // [34] nop
0010000000100111 // [35] j 39             -> salta para idx 39
0100000010011111 // [36] addi $2,$0,31    -> NAO executa (flush)
0100000010011111 // [37] addi $2,$0,31    -> NAO executa (flush)
0100000010011111 // [38] addi $2,$0,31    -> NAO executa
0100000111011001 // [39] addi $7,$0,25    -> $7=25  (destino do jump)
